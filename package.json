{
  "name": "@albertoescala/aesc-components",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./checkbox": {
      "types": "./dist/components/checkbox/index.d.ts",
      "import": "./dist/components/checkbox/index.js"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js"
    },
    "./link": {
      "types": "./dist/components/link/index.d.ts",
      "import": "./dist/components/link/index.js"
    },
    "./heading": {
      "types": "./dist/components/heading/index.d.ts",
      "import": "./dist/components/heading/index.js"
    },
    "./card": {
      "types": "./dist/components/card/index.d.ts",
      "import": "./dist/components/card/index.js"
    },
    "./breadcrumb": {
      "types": "./dist/components/breadcrumb/index.d.ts",
      "import": "./dist/components/breadcrumb/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tailwind:generate": "node scripts/generate-tailwind.mjs",
    "predev": "npm run tailwind:generate",
    "prebuild": "npm run tailwind:generate",
    "dev": "vite",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "vite build && npm run build:types",
    "analyze:bundle": "cross-env ANALYZE=true vite build",
    "analyze:size": "npm run build && node scripts/build-size.mjs",
    "check:size": "npm run build && node scripts/build-size.mjs --max-file-brotli-kb 5 --max-total-brotli-kb 10",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "playwright:install": "playwright install chromium",
    "test": "web-test-runner \"src/**/*.test.ts\" --config web-test-runner.config.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs": "vitepress dev docs",
    "build-docs": "vitepress build docs",
    "preview-docs": "vitepress preview docs"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@storybook/web-components": "^10.2.14",
    "@storybook/web-components-vite": "^10.2.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^6.0.3",
    "storybook": "^10.2.14",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4"
  }
}
